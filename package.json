{
	"name": "obsidian-cross-domain-connector",
	"version": "0.2.17",
	"description": "Discover serendipitous connections between notes in different domains",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck"
	},
	"keywords": [
		"obsidian",
		"pkm",
		"cross-domain",
		"serendipity",
		"embeddings"
	],
	"author": "eohjun",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.1",
		"@types/node": "^22.10.7",
		"esbuild": "^0.27.3",
		"obsidian": "latest",
		"obsidian-llm-shared": "github:eohjun/obsidian-llm-shared#v1.3.0",
		"typescript": "^6.0.2"
	}
}
